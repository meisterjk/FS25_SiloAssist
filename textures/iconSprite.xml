<texture>
    <meta>
        <filename>siloAssistAtlas.dds</filename>
        <size width="512" height="512" />
    </meta>
    <slices>
        <!-- Existing elements -->
        <slice id="panel" uvs="0px 0px 512px 64px"/>
        <slice id="play" uvs="4px 68px 56px 56px"/>
        <slice id="stop" uvs="68px 68px 56px 56px"/>
        <slice id="close" uvs="132px 68px 56px 56px"/>
